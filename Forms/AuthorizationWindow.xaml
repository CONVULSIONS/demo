<Window x:Class="Demo.Forms.AuthorizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo.Forms"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800" Icon="/Resuources/Icon.ico" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid Margin="207,10,207,0">
            <Label x:Name="AuthorizationLabel" Content="АВТОРИЗАЦИЯ" HorizontalAlignment="Center" Margin="0,35,0,0" VerticalAlignment="Top" FontFamily="Times New Roman" FontWeight="Bold"/>
            <Label x:Name="LoginLabel" Content="Логин:" HorizontalAlignment="Left" Margin="77,93,0,0" VerticalAlignment="Top" FontFamily="Times New Roman"/>
            <Label x:Name="PasswordLabel" Content="Пароль:" HorizontalAlignment="Left" Margin="71,193,0,0" VerticalAlignment="Top" FontFamily="Times New Roman"/>
            <TextBox x:Name="LoginTextBox" HorizontalAlignment="Left" Margin="219,97,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
            <TextBox x:Name="PasswordTextBox" HorizontalAlignment="Left" Margin="219,197,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
            <Button x:Name="AuthorizationButton" Content="Войти" HorizontalAlignment="Center" Margin="0,274,0,0" VerticalAlignment="Top" FontFamily="Times New Roman" Click="AuthorizationButton_Click"/>
            <Button x:Name="GuestButton" Content="Продолжить как гость" HorizontalAlignment="Center" Margin="0,317,0,0" VerticalAlignment="Top" FontFamily="Times New Roman" Click="GuestButton_Click"/>
        </Grid>
    </Grid>
</Window>
